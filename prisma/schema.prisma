generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Badge {
  id           String         @id
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  BadgeRule    BadgeRule[]
  CompanyBadge CompanyBadge[]
}

model BadgeRule {
  id           String       @id
  badgeId      String
  moduleId     String
  minScore     Float?
  required     Boolean      @default(true)
  Badge        Badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  SurveyModule SurveyModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([badgeId, moduleId])
  @@index([badgeId])
  @@index([moduleId])
}

model BenchmarkCohort {
  id                     String                   @id
  key                    String                   @unique
  title                  String
  companyType            CompanyType
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  BenchmarkRun           BenchmarkRun[]
  CompanyBenchmark       CompanyBenchmark[]
  CompanyBenchmarkCohort CompanyBenchmarkCohort[]
}

model BenchmarkRun {
  id              String          @id
  cohortId        String
  metricKey       String
  version         Int             @default(1)
  n               Int             @default(0)
  mean            Float           @default(0)
  stdev           Float?
  p10             Float?
  p25             Float?
  p50             Float?
  p75             Float?
  p90             Float?
  computedAt      DateTime        @default(now())
  BenchmarkCohort BenchmarkCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@unique([cohortId, metricKey, version])
  @@index([cohortId])
  @@index([metricKey])
}

model CapabilityEdge {
  id                                                   String         @id
  fromId                                               String
  toId                                                 String
  type                                                 String?
  weight                                               Float          @default(1.0)
  createdAt                                            DateTime       @default(now())
  CapabilityNode_CapabilityEdge_fromIdToCapabilityNode CapabilityNode @relation("CapabilityEdge_fromIdToCapabilityNode", fields: [fromId], references: [id], onDelete: Cascade)
  CapabilityNode_CapabilityEdge_toIdToCapabilityNode   CapabilityNode @relation("CapabilityEdge_toIdToCapabilityNode", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
}

model CapabilityNode {
  id                                                   String                     @id
  key                                                  String                     @unique
  title                                                String
  description                                          String?
  scope                                                CapabilityScope
  level                                                CapabilityLevel            @default(TIER1)
  weight                                               Float                      @default(1.0)
  active                                               Boolean                    @default(true)
  createdAt                                            DateTime                   @default(now())
  updatedAt                                            DateTime
  CapabilityEdge_CapabilityEdge_fromIdToCapabilityNode CapabilityEdge[]           @relation("CapabilityEdge_fromIdToCapabilityNode")
  CapabilityEdge_CapabilityEdge_toIdToCapabilityNode   CapabilityEdge[]           @relation("CapabilityEdge_toIdToCapabilityNode")
  CompanyCapabilityScore                               CompanyCapabilityScore[]
  InsightCapabilityRule                                InsightCapabilityRule[]
  ModuleCapability                                     ModuleCapability[]
  SurveyQuestionCapability                             SurveyQuestionCapability[]
}

model Company {
  id                     String                   @id
  name                   String
  slug                   String?                  @unique
  type                   CompanyType
  websiteUrl             String?
  logoUrl                String?
  shortDescription       String?
  longDescription        String?
  hqCountry              String?
  primaryMarket          String?
  verticalKey            String                   @default("ACCOUNTING")
  externalStatus         String?
  profileStatus          String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  CompanyBadge           CompanyBadge[]
  CompanyBenchmark       CompanyBenchmark[]
  CompanyBenchmarkCohort CompanyBenchmarkCohort[]
  CompanyCapabilityScore CompanyCapabilityScore[]
  FirmMaturityIndex      FirmMaturityIndex[]
  FirmMaturityMomentum   FirmMaturityMomentum[]
  FirmMaturitySnapshot   FirmMaturitySnapshot[]
  OrganizationContact    OrganizationContact[]
  ExternalProfileLink    ExternalProfileLink[]
  ExternalReviewsAuthored ExternalReviewSubmission[] @relation("ExternalReview_reviewerCompany")
  ExternalReviewsReceived ExternalReviewSubmission[] @relation("ExternalReview_subjectCompany")
  ExternalObservedSignalRollup ExternalObservedSignalRollup[] @relation("ExternalObservedSignal_subjectCompany")
  Product                Product[]
  SurveySubmission       SurveySubmission[]
  User                   User[]
}

model CompanyBadge {
  id        String   @id
  companyId String
  productId String?
  badgeId   String
  moduleId  String
  awardedAt DateTime @default(now())
  Badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  Company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  UnlockEvidence UnlockEvidence[]

  @@unique([companyId, productId, badgeId, moduleId])
  @@index([badgeId])
  @@index([companyId])
  @@index([companyId, productId, badgeId])
  @@index([companyId, productId, awardedAt])
}

model CompanyBenchmark {
  id              String          @id
  companyId       String
  cohortId        String
  metricKey       String
  version         Int             @default(1)
  score           Float           @default(0)
  percentile      Float           @default(0)
  computedAt      DateTime        @default(now())
  BenchmarkCohort BenchmarkCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  Company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, cohortId, metricKey, version])
  @@index([cohortId])
  @@index([companyId])
}

model CompanyBenchmarkCohort {
  id              String          @id
  companyId       String
  cohortId        String
  createdAt       DateTime        @default(now())
  BenchmarkCohort BenchmarkCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  Company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, cohortId])
  @@index([cohortId])
  @@index([companyId])
}

model CompanyCapabilityScore {
  id             String         @id
  companyId      String
  nodeId         String
  score          Float
  scoreVersion   Int            @default(1)
  computedAt     DateTime       @default(now())
  Company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  CapabilityNode CapabilityNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([companyId, nodeId, scoreVersion])
  @@index([companyId])
  @@index([nodeId])
}

model FirmMaturityIndex {
  id         String   @id
  companyId  String
  score      Float
  version    Int      @default(1)
  computedAt DateTime @default(now())
  bandMax    Float    @default(25)
  bandMin    Float    @default(0)
  tier       String   @default("FOUNDATIONAL")
  Company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, version])
  @@index([companyId])
}

model FirmMaturityMomentum {
  id         String   @id
  companyId  String
  version    Int      @default(1)
  windowN    Int      @default(3)
  delta1     Float    @default(0)
  delta2     Float    @default(0)
  accel      Float    @default(0)
  avgDelta   Float    @default(0)
  volatility Float    @default(0)
  trend      String   @default("FLAT")
  velocity   String   @default("STABLE")
  stability  String   @default("STABLE")
  computedAt DateTime @default(now())
  Company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, version])
  @@index([companyId])
}

model FirmMaturitySnapshot {
  id         String   @id
  companyId  String
  score      Float
  tier       String
  bandMin    Float
  bandMax    Float
  version    Int      @default(1)
  computedAt DateTime @default(now())
  Company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, computedAt])
  @@index([companyId, version])
}

model Insight {
  id                    String                  @id
  key                   String                  @unique
  title                 String
  body                  String
  tier                  Int                     @default(1)
  active                Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  InsightCapabilityRule InsightCapabilityRule[]
}

model InsightCapabilityRule {
  id             String         @id
  insightId      String
  nodeId         String
  minScore       Float
  required       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  Insight        Insight        @relation(fields: [insightId], references: [id], onDelete: Cascade)
  CapabilityNode CapabilityNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([insightId, nodeId])
  @@index([insightId])
  @@index([nodeId])
}

model ModuleCapability {
  id             String         @id
  moduleId       String
  nodeId         String
  weight         Float          @default(1.0)
  createdAt      DateTime       @default(now())
  SurveyModule   SurveyModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  CapabilityNode CapabilityNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([moduleId, nodeId])
  @@index([moduleId])
  @@index([nodeId])
}

model Product {
  id                  String                @id
  companyId           String
  parentProductId     String?
  name                String
  slug                String?
  category            String?
  productKind         ProductKind           @default(POINT_SOLUTION)
  websiteUrl          String?
  logoUrl             String?
  shortDescription    String?
  longDescription     String?
  apiEndpoint         String?
  primaryMarket       String?
  verticalKey         String                @default("ACCOUNTING")
  externalStatus      String?
  profileStatus       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  Company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ParentProduct       Product?              @relation("ProductHierarchy", fields: [parentProductId], references: [id], onDelete: SetNull)
  ChildProducts       Product[]             @relation("ProductHierarchy")
  ExternalProfileLink ExternalProfileLink[]
  ExternalReviewSubmission ExternalReviewSubmission[]
  ExternalObservedSignalRollup ExternalObservedSignalRollup[]
  CompanyBadge        CompanyBadge[]
  SurveySubmission    SurveySubmission[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([parentProductId])
}

model OrganizationContact {
  id          String   @id
  companyId   String
  name        String
  title       String?
  email       String?
  contactRole String?
  source      String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
}

model ExternalProfileLink {
  id                 String    @id
  source             String
  externalEntityType String
  externalRecordId   String
  externalSlug       String?
  canonicalUrl       String?
  companyId          String?
  productId          String?
  claimStatus        String?
  syncMode           String?
  lastSyncedAt       DateTime?
  rawSnapshotJson    Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  Company            Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Product            Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([source, externalEntityType, externalRecordId])
  @@index([companyId])
  @@index([productId])
}

model SurveyModule {
  id               String             @id
  key              String             @unique
  title            String
  description      String?
  axis             ModuleAxis         @default(SELF)
  scope            ModuleScope
  version          Int                @default(1)
  weight           Float              @default(1.0)
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  BadgeRule        BadgeRule[]
  ModuleCapability ModuleCapability[]
  SurveyQuestion   SurveyQuestion[]
  SurveySubmission SurveySubmission[]
  ExternalReviewSubmission ExternalReviewSubmission[]
  ExternalObservedSignalRollup ExternalObservedSignalRollup[]
}

model SurveyQuestion {
  id                       String                     @id
  moduleId                 String
  key                      String
  prompt                   String
  inputType                QuestionInputType
  weight                   Float                      @default(1.0)
  order                    Int
  required                 Boolean                    @default(true)
  createdAt                DateTime                   @default(now())
  meta                     Json?
  updatedAt                DateTime
  SurveyModule             SurveyModule               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  SurveyQuestionCapability SurveyQuestionCapability[]
}

model SurveyQuestionCapability {
  id             String         @id
  questionId     String
  nodeId         String
  weight         Float          @default(1.0)
  createdAt      DateTime       @default(now())
  CapabilityNode CapabilityNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  SurveyQuestion SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, nodeId])
  @@index([nodeId])
  @@index([questionId])
}

model SurveySubmission {
  id                   String       @id
  version              Int          @default(1)
  answers              Json
  score                Int          @default(0)
  signalIntegrityScore Float        @default(1.0)
  integrityFlags       Json?
  createdAt            DateTime     @default(now())
  moduleId             String
  companyId            String
  productId            String?
  scoreVersion         Int          @default(1)
  weightedAvg          Float?
  answeredCount        Int          @default(0)
  scaleMax             Int          @default(100)
  scaleMin             Int          @default(0)
  totalWeight          Float        @default(0)
  Company              Company      @relation(fields: [companyId], references: [id])
  Product              Product?     @relation(fields: [productId], references: [id])
  SurveyModule         SurveyModule @relation(fields: [moduleId], references: [id])
  UnlockEvidence       UnlockEvidence[]

  @@index([companyId, moduleId, createdAt])
  @@index([companyId, productId, moduleId, createdAt])
}

model ExternalReviewSubmission {
  id                   String               @id
  reviewerCompanyId    String
  subjectCompanyId     String
  subjectProductId     String?
  moduleId             String
  answers              Json
  normalizedDimensions Json?
  score                Int?
  weightedAvg          Float?
  scoreVersion         Int?
  signalIntegrityScore Float?
  integrityFlags       Json?
  reviewStatus         ExternalReviewStatus @default(SUBMITTED)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  reviewerCompany      Company              @relation("ExternalReview_reviewerCompany", fields: [reviewerCompanyId], references: [id], onDelete: Cascade)
  subjectCompany       Company              @relation("ExternalReview_subjectCompany", fields: [subjectCompanyId], references: [id], onDelete: Cascade)
  subjectProduct       Product?             @relation(fields: [subjectProductId], references: [id], onDelete: Cascade)
  surveyModule         SurveyModule         @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([reviewerCompanyId, createdAt])
  @@index([subjectCompanyId, subjectProductId, moduleId, createdAt])
  @@index([moduleId, reviewStatus, createdAt])
}

model ExternalObservedSignalRollup {
  id                 String       @id
  moduleId           String
  subjectCompanyId   String
  subjectProductId   String?
  reviewCount        Int
  scoreAvg           Float?
  weightedAvgAvg     Float?
  signalIntegrityAvg Float?
  latestReviewAt     DateTime?
  rollupVersion      Int          @default(1)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  surveyModule       SurveyModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  subjectCompany     Company      @relation("ExternalObservedSignal_subjectCompany", fields: [subjectCompanyId], references: [id], onDelete: Cascade)
  subjectProduct     Product?     @relation(fields: [subjectProductId], references: [id], onDelete: Cascade)
  UnlockEvidence     UnlockEvidence[]

  @@unique([moduleId, subjectCompanyId, subjectProductId, rollupVersion])
  @@index([subjectCompanyId, subjectProductId])
  @@index([moduleId, latestReviewAt])
}

model UnlockEvidence {
  id                            String                   @id
  companyBadgeId                String
  sourceType                    UnlockEvidenceSourceType
  surveySubmissionId            String?
  externalObservedSignalRollupId String?
  ruleKey                       String
  detailsJson                   Json?
  createdAt                     DateTime                 @default(now())
  companyBadge                  CompanyBadge             @relation(fields: [companyBadgeId], references: [id], onDelete: Cascade)
  surveySubmission              SurveySubmission?        @relation(fields: [surveySubmissionId], references: [id], onDelete: Cascade)
  externalObservedSignalRollup  ExternalObservedSignalRollup? @relation(fields: [externalObservedSignalRollupId], references: [id], onDelete: Cascade)

  @@index([companyBadgeId, createdAt])
  @@index([surveySubmissionId])
  @@index([externalObservedSignalRollupId])
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime
  companyId String?
  Company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

enum CapabilityLevel {
  TIER1
  TIER2
  TIER3
}

enum CapabilityScope {
  FIRM
  VENDOR
  PRODUCT
  ENTERPRISE
}

enum CompanyType {
  FIRM
  VENDOR
}

enum ModuleScope {
  FIRM
  VENDOR
  PRODUCT
  ENTERPRISE
}

enum ModuleAxis {
  SELF
  EXTERNAL_REVIEW
}

enum ExternalReviewStatus {
  SUBMITTED
  FINALIZED
  REJECTED
}

enum UnlockEvidenceSourceType {
  SELF_SUBMISSION
  EXTERNAL_REVIEW_ROLLUP
}

enum QuestionInputType {
  SLIDER
  SELECT
  MULTISELECT
  BOOLEAN
  NUMBER
  TEXT
}

enum ProductKind {
  PLATFORM
  SUITE
  MODULE
  POINT_SOLUTION
  SERVICE
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}
