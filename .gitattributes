# Normalize all text to LF in repo; working tree handled by git
* text=auto eol=lf

# Common types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
# JSON + JS: enforce LF + no BOM via normalization
*.json  text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
